<div class="container mx-auto px-4 py-8">
  <div class="card bg-base-100 shadow-xl max-w-lg mx-auto">
    <div class="card-body">
      <h2 class="card-title">アカウント設定</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tbody>
            <tr>
              <td class="font-bold">ニックネーム</td>
              <td><%= current_user.name %></td>
            </tr>
            <tr>
              <td class="font-bold">メールアドレス</td>
              <td><%= current_user.email %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="grid grid-cols-2 gap-4 mt-4">
        <%= link_to "編集する", edit_user_registration_path, class: "btn btn-primary" %>
        <%= link_to "ホームへ", home_path, class: "btn btn-outline" %>
      </div>
    </div>
  </div>
</div>