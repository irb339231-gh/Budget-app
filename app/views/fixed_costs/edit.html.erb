<div class="container mx-auto px-4 py-8">
  <div class="card bg-base-100 shadow-xl max-w-lg mx-auto">
    <div class="card-body">
      <h2 class="card-title">固定費の編集</h2>

      <%= form_with model: @fixed_cost, url: fixed_cost_path(@fixed_cost), method: :patch, scope: :fixed_cost do |f| %>
        <%= render "devise/shared/error_messages", resource: @fixed_cost %>

        <div class="form-control mb-4">
          <%= f.label :name, "固定費名", class: "label" %>
          <%= f.text_field :name, class: "input input-bordered w-full",
              placeholder: "例：保険、スマホ代" %>
        </div>

        <div class="form-control mb-6">
          <%= f.label :amount, "金額", class: "label" %>
          <%= f.number_field :amount, class: "input input-bordered w-full",
              placeholder: "例：1000000" %>
        </div>

        <div class="form-control">
          <%= f.submit "更新する", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <%= link_to "戻る", edit_all_fixed_costs_path, class: "btn btn-outline w-full mt-4" %>
    </div>
  </div>
</div>