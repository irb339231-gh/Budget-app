<div class="container mx-auto px-4 py-8">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <div class="card bg-primary text-primary-content shadow-xl mb-6">
        <div class="card-body text-center">
          <h2 class="text-2xl font-bold">固定費一覧</h2>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>固定費名</th>
              <th class="text-right">金額</th>
            </tr>
          </thead>
          <tbody>
            <% @fixed_costs.each do |fixed_cost| %>
              <tr>
                <td><%= fixed_cost.name %></td>
                <td class="text-right">¥<%= number_with_delimiter(fixed_cost.amount) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="grid grid-cols-2 gap-4 mt-4">
        <%= link_to "編集する", edit_all_fixed_costs_path, class: "btn btn-outline" %>
        <%= link_to "ホームへ", home_path, class: "btn btn-outline" %>
      </div>
    </div>
  </div>
</div>