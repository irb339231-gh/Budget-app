<div class="container mx-auto px-4 py-8">
  <div class="card bg-base-100 shadow-xl max-w-lg mx-auto">
    <div class="card-body">
      <h2 class="card-title">収入の編集</h2>

      <%= form_with model: @expenditure do |f| %>
        <%= render "devise/shared/error_messages", resource: @expenditure %>

        <div class="form-control mb-4">
          <%= f.label :name, "収入名", class: "label" %>
          <%= f.text_field :name, class: "input input-bordered w-full",
              placeholder: "例：貯蓄、退職金" %>
        </div>

        <div class="form-control mb-6">
          <%= f.label :amount, "金額", class: "label" %>
          <%= f.number_field :amount, class: "input input-bordered w-full",
              placeholder: "例：1000000" %>
        </div>

        <div class="form-control">
          <%= f.submit "更新する", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <%= link_to "戻る", edit_all_expenditures_path, class: "btn btn-outline w-full mt-4" %>
    </div>
  </div>
</div>