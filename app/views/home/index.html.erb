<div class="container mx-auto px-4 py-8">

  <%# 今使える金額の表示 %>
  <div class="card bg-primary text-primary-content shadow-xl mb-6">
    <div class="card-body text-center">
      <p class="text-lg">あなたの今使える金額は</p>
      <p class="text-5xl font-bold">¥0</p>
    </div>
  </div>
  
  <%# 転職活動期間 %>
  <div class="card bg-neutral shadow-md mb-6">
    <div class="card-body">
      <h2 class="card-title">転職活動期間</h2>
      <div class="flex gap-4 items-center">
        <div class="form-control">
          <label class="label">
            <span class="label-text">開始日</span>
          </label>
          <input type="date" class="input input-bordered" disabled value = "未設定">
        </div>
        <span class="mt-6">〜</span>
        <div class="form-control">
          <label class="label">
            <span class="label-text">終了日</span>
          </label>
            <input type="date" class="input input-bordered" >
        </div>
      </div>
    </div>
  </div>  

  <%# 内訳表示 %>
  <div class="card bg-neutral shadow-md mb-6">
    <div class="card-body">
      <h2 class="card-title">内訳</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <tbody>
            <tr>
              <td>収入</td>
              <td class="text-right">¥0</td>
            </tr>
            <tr>
              <td>将来の支出</td>
              <td class="text-right">¥0</td>
            </tr>
            <tr>
              <td>固定費</td>
              <td class="text-right">¥0</td>
            </tr>
            <tr>
              <td>随時支出</td>
              <td class="text-right">¥0</td>
            </tr>
            <tr>
              <td>随時収入</td>
              <td class="text-right">¥0</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# 随時支出・収入の入力欄 %>
  <div class="card bg-neutral shadow-md mb-6">
    <div class="card-body">
      <h2 class="card-title">随時支出・収入</h2>
      <div class="flex gap-4 items-center">
        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">随時支出</span>
          </label>
          <input type="number" placeholder="¥0" class="input input-bordered input-sum w-36">
        </div>
        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">随時収入</span>
          </label>
          <input type="number" placeholder="¥0" class="input input-bordered input-sm w-36">
        </div>
      </div>
    </div>
  </div>

  <%# 各入力フォームへの導線 %>
  <div class="grid grid-cols-3 gap-4">
    <a href="<%= incomes_path %>" class="btn btn-outline">収入</a>
    <a href="<%= future_expenses_path %>" class="btn btn-outline">将来の支出</a>
    <a href="#" class="btn btn-outline">固定費</a>
  </div>
</div>
