<div class="container mx-auto px-4 py-8">

  <%# 今使える金額の表示 %>
  <div class="card bg-primary text-primary-content shadow-xl mb-6">
    <div class="card-body text-center">
      <p class="text-lg">あなたの今使える金額は</p>
      <p class="text-5xl font-bold">¥<%= number_with_delimiter(@available_amount) %></p>
    </div>
  </div>
  
<%# 転職活動期間 %>
<div class="card bg-neutral shadow-md mb-6">
  <div class="card-body">
    <h2 class="card-title">転職活動期間</h2>
    <%= form_with model: current_user, url: update_job_search_path, method: :patch do |f| %>
      <div class="flex gap-4 items-center">
        <div class="form-control">
          <label class="label">
            <span class="label-text">開始日</span>
          </label>
          <%= f.date_field :job_search_start_month,
              class: "input input-bordered",
              value: current_user.job_search_start_month %>
        </div>
        <span class="mt-6">〜</span>
        <div class="form-control">
          <label class="label">
            <span class="label-text">終了日</span>
          </label>
          <%= f.date_field :job_search_end_month,
              class: "input input-bordered",
              value: current_user.job_search_end_month %>
        </div>
      </div>
      <div class="mt-4">
        <%= f.submit "設定する", class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  </div>
</div>

  <%# 内訳表示 %>
  <div class="card bg-neutral shadow-md mb-6">
    <div class="card-body">
      <h2 class="card-title">内訳</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <tbody>
            <tr>
              <td>収入</td>
              <td class="text-right">¥<%= number_with_delimiter(current_user.total_income) %></td>
            </tr>
            <tr>
              <td>将来の支出</td>
              <td class="text-right">¥<%= number_with_delimiter(current_user.total_future_expenses) %></td>
            </tr>
            <tr>
              <td>固定費</td>
              <td class="text-right">¥<%= number_with_delimiter(current_user.total_fixed_costs) %></td>
            </tr>
            <tr>
              <td>随時支出</td>
              <td class="text-right">¥<%= number_with_delimiter(current_user.total_transactions_expenses) %></td>
            </tr>
            <tr>
              <td>随時収入</td>
              <td class="text-right">¥<%= number_with_delimiter(current_user.total_transactions_incomes) %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# 随時支出・収入の入力欄 %>
  <div class="card bg-neutral shadow-md mb-6">
    <div class="card-body">
      <div class="flex justify-between items-center mb-4">
        <h2 class="card-title">随時支出・収入</h2>
        <%= link_to "履歴を見る", transactions_path, class: "btn btn-outline btn-sm" %>
      </div>
      <div class="grid grid-cols-2 gap-4">

        <%# 随時支出フォーム %>
        <%= form_with url: transactions_path, method: :post, scope: :transaction do |f| %>
          <%= f.hidden_field :category, value: :expense %>
          <div class="form-control">
            <label class="label">
              <span class="label-text">随時支出</span>
          </label>
          <%= f.number_field :amount, placeholder: "¥0", class: "input input-bordered w-full" %>
          <%= f.submit "登録", class: "btn btn-primary btn-sm mt-2" %>
        </div>
        <% end %>

        <%# 随時収入フォーム %>
        <%= form_with url: transactions_path, method: :post, scope: :transaction do |f| %>
          <%= f.hidden_field :category, value: :income %>
          <div class="form-control">
            <label class="label">
              <span class="label-text">随時収入</span>
            </label>
            <%= f.number_field :amount, placeholder: "¥0", class: "input input-bordered w-full" %>
            <%= f.submit "登録", class: "btn btn-primary btn-sm mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# 各入力フォームへの導線 %>
  <div class="grid grid-cols-3 gap-4">
    <a href="<%= incomes_path %>" class="btn btn-outline">収入</a>
    <a href="<%= future_expenses_path %>" class="btn btn-outline">将来の支出</a>
    <a href="<%= fixed_costs_path %>" class="btn btn-outline">固定費</a>
  </div>
</div>
