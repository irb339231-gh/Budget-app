<div class="container mx-auto px-4 py-8">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title">収入編集</h2>

      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>収入名</th>
              <th class="text-right">金額</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @incomes.each do |income| %>
              <tr>
                <td><%= income.name %></td>
                <td class="text-right">¥<%= number_with_delimiter(income.amount) %></td>
                <td class="text-right flex gap-2">
                  <%= link_to "編集", edit_income_path(income), class: "btn btn-outline btn-xs" %>
                  <%= button_to "削除", income_path(income), method: :delete,
                      class: "btn btn-error btn-xs",
                      data: { turbo_confirm: "削除してもよいですか？" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="grid grid-cols-2 gap-4 mt-4">
        <%= link_to "追加する", new_income_path, class: "btn btn-primary" %>
        <%= link_to "戻る", incomes_path, class: "btn btn-outline" %>
      </div>
    </div>
  </div>
</div>