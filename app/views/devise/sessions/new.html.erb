<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-96 bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title justify-center text-2xl mb-4">ログイン</h2>

      <%= form_with model: resource, as: resource_name, url: session_path(resource_name) do |f| %>

        <div class="form-control mb-3">
          <%= f.label :email, "メールアドレス", class: "label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mb-6">
          <%= f.label :password, "パスワード", class: "label" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "input input-bordered w-full" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control mb-3">
            <label class="cursor-pointer label">
              <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
              <span class="label-text">ログイン状態を保持する</span>
            </label>
          </div>
        <% end %>

        <div class="form-control">
          <%= f.submit "ログイン", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>