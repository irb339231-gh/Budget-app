<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-96 bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title justify-center text-2xl mb-4">パスワードをお忘れの方</h2>

      <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :post do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-control mb-4">
          <%= f.label :email, "メールアドレス", class: "label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.submit "パスワードリセットメールを送信する", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>