<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-96 bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title justify-center text-2xl mb-4">パスワード再設定</h2>

      <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :put do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="form-control mb-4">
          <%= f.label :password, "新しいパスワード", class: "label" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-500 mb-1"><%= @minimum_password_length %>文字以上</p>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mb-6">
          <%= f.label :password_confirmation, "新しいパスワード確認", class: "label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.submit "パスワードを変更する", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>